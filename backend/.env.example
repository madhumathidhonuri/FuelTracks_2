# FuelTracks Backend Configuration
# Copy this file to .env and update values

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fueltracks
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Email (for alerts, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=FuelTracks <noreply@fueltracks.com>

# SMS (for emergency alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ============================================
# TCP Server Ports (GPS Device Protocols)
# ============================================

# Legacy TCP Server (backward compatibility)
GPS_PORT=9000

# AIS-140 Protocol (tnavic devices)
TCP_AIS140_PORT=9001

# BSTP-15 Protocol (BS Technotronics devices)
TCP_BSTP15_PORT=9002

# BSTPL-17 Protocol (BS Technotronics devices)
TCP_BSTPL17_PORT=9003